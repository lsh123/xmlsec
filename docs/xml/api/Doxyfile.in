PROJECT_NAME           = xmlsec
PROJECT_NUMBER         = @VERSION@
OUTPUT_DIRECTORY       = @abs_top_builddir@/docs/xml/api
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = NO
OUTPUT_LANGUAGE        = English
BRIEF_MEMBER_DESC      = YES
REPEAT_BRIEF           = YES
ALWAYS_DETAILED_SEC    = NO
INLINE_INHERITED_MEMB  = NO
FULL_PATH_NAMES        = YES
STRIP_FROM_PATH        = @abs_top_srcdir@
SHORT_NAMES            = NO
JAVADOC_AUTOBRIEF      = NO
QT_AUTOBRIEF           = NO
MULTILINE_CPP_IS_BRIEF = NO
INHERIT_DOCS           = YES
SEPARATE_MEMBER_PAGES  = NO
TAB_SIZE               = 8
OPTIMIZE_OUTPUT_FOR_C  = YES
TYPEDEF_HIDES_STRUCT   = YES
EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_PRIV_VIRTUAL   = NO
EXTRACT_PACKAGE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = NO
EXTRACT_LOCAL_METHODS  = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
HIDE_FRIEND_COMPOUNDS  = YES
HIDE_IN_BODY_DOCS      = NO
INTERNAL_DOCS          = NO
CASE_SENSE_NAMES       = YES
HIDE_SCOPE_NAMES       = NO
HIDE_COMPOUND_REFERENCE= NO
SHOW_INCLUDE_FILES     = YES
SHOW_GROUPED_MEMB_INC  = NO
FORCE_LOCAL_INCLUDES   = NO
INLINE_INFO            = YES
SORT_MEMBER_DOCS       = YES
SORT_BRIEF_DOCS        = NO
SORT_MEMBERS_CTORS_1ST = NO
SORT_GROUP_NAMES       = YES
SORT_BY_SCOPE_NAME     = NO
STRICT_PROTO_MATCHING  = NO
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_MAN           = NO
GENERATE_RTF           = NO
GENERATE_DOCBOOK       = NO
GENERATE_XML           = YES
HTML_OUTPUT            = html
XML_OUTPUT             = xml
INPUT                  = @abs_top_srcdir@/include \
                         @abs_top_srcdir@/src
FILE_PATTERNS          = *.h \
                         *.c
RECURSIVE              = YES
EXCLUDE_PATTERNS       = */.libs/* \
                         */Makefile* \
                         */version.h.in \
                         */src/*.h \
                         */src/*/*.h
EXAMPLE_PATH           = @abs_top_srcdir@/examples
QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES
WARN_AS_ERROR          = NO
WARN_LOGFILE           =
INPUT_ENCODING         = UTF-8
FILE_VERSION_FILTER    =
MARKDOWN_SUPPORT       = YES
TOC_INCLUDE_HEADINGS   = 0
AUTOLINK_SUPPORT       = YES
BUILTIN_STL_SUPPORT    = NO
CPP_CLI_SUPPORT        = NO
SIP_SUPPORT            = NO
IDL_PROPERTY_SUPPORT   = YES
DISTRIBUTE_GROUP_DOC   = YES
GROUP_NESTED_COMPOUNDS = NO
SUBGROUPING            = YES
INLINE_GROUPED_CLASSES = NO
INLINE_SIMPLE_STRUCTS  = NO
LOOKUP_CACHE_SIZE      = 0
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = NO
SEARCH_INCLUDES        = YES
INCLUDE_PATH           = @abs_top_srcdir@/docs/xml/api \
                         @abs_top_srcdir@/include \
                         @abs_top_srcdir@/src
INCLUDE_FILE_PATTERNS  = *.h
PREDEFINED             = XMLSEC_EXPORT= \
                         XMLSEC_EXPORT_VAR= \
                         XMLSEC_CRYPTO_EXPORT= \
                         XMLSEC_PRIVATE= \
                         XMLSEC_DEPRECATED= \
                         XMLSEC_ERRORS_PRINTF_ATTRIBUTE(x,y)= \
                         HCERTSTORE=void* \
                         HCRYPTKEY=void* \
                         HCRYPTPROV=void* \
                         PCCERT_CONTEXT=void* \
                         LPTSTR=char* \
                         LPCTSTR=const\ char* \
                         LPWSTR=wchar_t* \
                         LPCWSTR=const\ wchar_t* \
                         BOOL=int \
                         DWORD=unsigned\ long \
                         PBYTE=unsigned\ char* \
                         BYTE=unsigned\ char \
                         BCRYPT_ALG_HANDLE=void* \
                         BCRYPT_KEY_HANDLE=void* \
                         NCRYPT_KEY_HANDLE=void* \
                         NCRYPT_PROV_HANDLE=void* \
                         __WIN32__=1 \
                         _WIN32=1 \
                         __GNUC__=1 \
                         XMLSEC_ATTRIBUTE_UNUSED=
EXPAND_AS_DEFINED      =
SKIP_FUNCTION_MACROS   = YES
TAGFILES               =
GENERATE_TAGFILE       =
ALLEXTERNALS           = NO
EXTERNAL_GROUPS        = YES
EXTERNAL_PAGES         = YES
HIDE_UNDOC_RELATIONS   = YES
HAVE_DOT               = NO
